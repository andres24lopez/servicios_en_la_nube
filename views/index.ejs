<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Calculadora de Construcción</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>Calculadora de Construcción</h1>

        <form action="/calcular" method="POST">
            <input type="number" step="0.01" name="largo" placeholder="Largo (m)" required>
            <input type="number" step="0.01" name="ancho" placeholder="Ancho (m)" required>
            <input type="number" step="0.01" name="alto" placeholder="Alto (m)" required>

            <input type="number" step="0.01" name="costoCemento" placeholder="Costo Cemento" required>
            <input type="number" step="0.01" name="costoArena" placeholder="Costo Arena" required>
            <input type="number" step="0.01" name="costoBlock" placeholder="Costo Block" required>

            <button type="submit">Calcular</button>
        </form>

        <% if (resultado) { %>
            <div class="resultado">
                <h2>Resultados</h2>
                <p><strong>Área:</strong> <%= resultado.area %> m²</p>
                <p><strong>Volumen:</strong> <%= resultado.volumen %> m³</p>
                <p><strong>Cemento:</strong> <%= resultado.cemento %> bolsas</p>
                <p><strong>Arena:</strong> <%= resultado.arena %> m³</p>
                <p><strong>Blocks:</strong> <%= resultado.block %> unidades</p>
                <p><strong>Total:</strong> Q <%= resultado.total %></p>
            </div>
        <% } %>
    </div>
</body>
</html>